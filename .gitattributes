# Auto-detect text files and normalize line endings in the repository.
* text=auto

# Repository metadata and documentation.
/.gitattributes text eol=lf
/.gitignore text eol=lf
*.md text eol=lf
*.txt text eol=lf

# Java project text files.
*.java text eol=lf
*.gradle text eol=lf
*.properties text eol=lf
*.xml text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.csv text eol=lf

# Scripts.
*.sh text eol=lf
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files.
*.pdf binary
*.pptx binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.jar binary
*.class binary
